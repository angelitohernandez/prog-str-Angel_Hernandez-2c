<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.demopruebapractica.HelloController"
      style="-fx-background-color: #ffffff;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Directorio de Emergencia" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Nombre:"/>
        <TextField fx:id="txtNombre" GridPane.columnIndex="1" promptText="Nombre completo"/>

        <Label text="Teléfono:" GridPane.rowIndex="1"/>
        <TextField fx:id="txtTelefono" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="10 dígitos"/>

        <Label text="Parentesco:" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cbParentesco" editable="true"
                  style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-background-insets: 0;"
                  GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200"/>
    </GridPane>

    <Separator/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Agregar" onAction="#onAgregar" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Buscar" onAction="#onBuscar"/>
        <Button text="Actualizar" onAction="#onActualizar" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Eliminar" onAction="#onEliminar" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Limpiar" onAction="#onLimpiar"/>
    </HBox>

    <ListView fx:id="lvContactos" VBox.vgrow="ALWAYS" />

    <Label fx:id="lblMensaje" text="Bienvenido" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
</VBox>