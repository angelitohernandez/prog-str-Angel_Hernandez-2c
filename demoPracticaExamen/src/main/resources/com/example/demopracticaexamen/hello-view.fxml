<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demopracticaexamen.HelloController">

    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

    <GridPane hgap="10" vgap="10">
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250" />

        <Label text="Teléfono :" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Parentesco:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="txtParentesco" GridPane.columnIndex="1" GridPane.rowIndex="2"  />
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Agregar" onAction="#onAgregarClick" />
        <Button text="Buscar" onAction="#onBuscarClick" />
        <Button text="Actualizar" onAction="#onActualizarClick" />
        <Button text="Eliminar" onAction="#onEliminarClick" />
        <Button text="Limpiar" onAction="#onLimpiarClick" />
    </HBox>

    <ListView fx:id="listViewContactos" VBox.vgrow="ALWAYS" />

    <Label fx:id="lblEstado" text="Listo" style="-fx-font-weight: bold;" />
</VBox>